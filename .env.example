# ============================================================
# CollegeNCourses Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ============================================================

# ------ SANITY CMS ------
# Get these from sanity.io/manage → your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
# Sanity API token with write access (for mutations, if needed server-side)
SANITY_API_TOKEN=your_sanity_api_token

# ------ SUPABASE ------
# Get these from app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key — SERVER ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------ SITE ------
NEXT_PUBLIC_SITE_URL=https://collegencourses.com

# ------ OTP VERIFICATION ------
# Set to false to disable OTP entirely (e.g. if SMS provider is down).
# Requires a redeploy to take effect.
NEXT_PUBLIC_OTP_ENABLED=true
# SMS provider credentials (SMSalert.co.in)
SMS_API_KEY=your_smsalert_api_key
SMS_SENDER_ID=XXXXXX
SMS_DLT_TEMPLATE_ID=your_dlt_template_id
# Message template — keep {OTP} placeholder exactly as-is
SMS_OTP_TEMPLATE=Your OTP for CollegeNCourses verification is {OTP}. Valid for 10 minutes. Do not share with anyone.

# ------ ADMIN ------
# Protects the /api/admin/import and /api/admin/export routes.
# Set any strong random string here and enter it on the Import/Export admin page.
ADMIN_SECRET=your_admin_secret

# ------ AGILE CRM ------
# Get API key from Agile CRM → Admin Settings → API & Analytics → REST API Key
AGILE_CRM_DOMAIN=yoursubdomain
AGILE_CRM_EMAIL=your_admin_email@example.com
AGILE_CRM_API_KEY=your_agile_rest_api_key

# ------ OPTIONAL: Analytics / Ads ------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=xxxxxxxxxxxxxxxx
