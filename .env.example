# ============================================================
# CollegeNCourses Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ============================================================

# ------ SANITY CMS ------
# Get these from sanity.io/manage → your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
# Sanity API token with write access (for mutations, if needed server-side)
SANITY_API_TOKEN=your_sanity_api_token

# ------ SUPABASE ------
# Get these from app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key — SERVER ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------ SITE ------
NEXT_PUBLIC_SITE_URL=https://collegencourses.com

# ------ OPTIONAL: Analytics / Ads ------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=xxxxxxxxxxxxxxxx
